# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./.wannasing/wanasing.db

# 文件存储配置
AUDIO_ROOT=./.wannasing/data/audio
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=.mp3,.wav,.m4a

# 服务配置
API_PORT=8000
DEBUG=true

# ── SMTP 邮件配置（用于发送验证码） ────────────────────────────────────────────
# 如果你希望用户收到真实的验证码邮件，请填写下面的 SMTP 信息。
# 复制本文件为 .env（同目录），填入实际值。
#
# 常见邮箱 SMTP 服务器：
#   Gmail:   smtp.gmail.com      端口 587 → 需开启"应用专用密码"
#   QQ邮箱:  smtp.qq.com         端口 587 → 需开启 SMTP 获取授权码
#   163邮箱: smtp.163.com        端口 587 → 需开启 SMTP 获取授权码
#   Outlook: smtp-mail.outlook.com 端口 587
#
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# 可选，默认使用 SMTP_USER
# SMTP_FROM=WannaSing <noreply@yourdomain.com>